# Production environment variables for Docker Stack

# Application
APP_NAME=Colibri
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.colibri-rss.com
APP_LOCALE=en
APP_MAINTENANCE_DRIVER=file

# Database (SQLite)
DB_CONNECTION=sqlite
DB_DATABASE=/app/database/database.sqlite
DB_FOREIGN_KEYS=true

# Queue, Cache, Session
QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# File Storage
FILESYSTEM_DISK=local
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=https://d1mc6q6crhpy86.cloudfront.net

# AI (Gemini)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RETRIES=3
GEMINI_TIMEOUT=30
GEMINI_RETRY_SLEEP_MS=200
GEMINI_CONNECT_TIMEOUT=10

# RSS
RSS_CONNECT_TIMEOUT=5
RSS_TIMEOUT=10
RSS_RETRY_TIMES=2
RSS_RETRY_SLEEP_MS=200
RSS_USER_AGENT=ColibriRSS/1.0

# Logo
LOGO_CONNECT_TIMEOUT=5
LOGO_TIMEOUT=10
LOGO_RETRY_TIMES=1
LOGO_RETRY_SLEEP_MS=0
LOGO_MAX_SIZE_BYTES=1048576
LOGO_USER_AGENT=ColibriLogo/1.0

# Secret file paths (Docker Swarm mounts these)
APP_KEY_FILE=/run/secrets/app_key
GEMINI_API_KEY_FILE=/run/secrets/google-api-key
AWS_ACCESS_KEY_ID_FILE=/run/secrets/aws-access-key
AWS_SECRET_ACCESS_KEY_FILE=/run/secrets/aws-secret-access-key
AWS_BUCKET_FILE=/run/secrets/logo-s3-bucket
AWS_DEFAULT_REGION_FILE=/run/secrets/logo-s3-region

